<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15.0" style="-fx-background-color: #f4f7f6;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.MainController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <HBox alignment="CENTER" spacing="10.0" style="-fx-background-color: #ffffff; -fx-padding: 10; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
        <TextField fx:id="loginField" promptText="Логин" prefWidth="100.0" />
        <PasswordField fx:id="passwordField" promptText="Пароль" prefWidth="100.0" />
        <Button onAction="#handleLogin" style="-fx-background-color: #2c3e50; -fx-text-fill: white;" text="Войти" />
        <Button onAction="#loginAsUser" style="-fx-background-color: #3498db; -fx-text-fill: white;" text="Режим пользователя" />
        <Region HBox.hgrow="ALWAYS" />
        <Label fx:id="statusLabel" text="Роль: Гость" textFill="#7f8c8d" />
    </HBox>

    <TextField fx:id="searchField" promptText="Поиск товара..." />

    <TableView fx:id="productTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="nameColumn" prefWidth="200.0" text="Название" />
            <TableColumn fx:id="countColumn" prefWidth="100.0" text="Количество" />
            <TableColumn fx:id="priceColumn" prefWidth="100.0" text="Цена" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <HBox fx:id="userPanel" alignment="CENTER_LEFT" managed="false" spacing="15.0" style="-fx-background-color: #d1ecf1; -fx-padding: 15; -fx-background-radius: 10;" visible="false">
        <Label style="-fx-font-weight: bold;" text="Выдача товара:" />
        <Spinner fx:id="issueAmountSpinner" editable="false" prefWidth="100.0" />
        <Button onAction="#handleIssue" style="-fx-background-color: #17a2b8; -fx-text-fill: white;" text="Списать со склада" />
    </HBox>

    <VBox fx:id="adminPanel" managed="false" spacing="10.0" style="-fx-background-color: #f8d7da; -fx-padding: 15; -fx-background-radius: 10;" visible="false">
        <HBox spacing="10.0">
            <TextField fx:id="nameInput" promptText="Название" HBox.hgrow="ALWAYS" />
            <TextField fx:id="countInput" prefWidth="80.0" promptText="Кол-во" />
            <TextField fx:id="priceInput" prefWidth="80.0" promptText="Цена" />
        </HBox>
        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <Button onAction="#handleAdd" style="-fx-background-color: #28a745; -fx-text-fill: white;" text="Добавить" />
            <Button onAction="#handleUpdatePrice" style="-fx-background-color: #ffc107;" text="Обновить цену" />
            <Button onAction="#handleDelete" style="-fx-background-color: #dc3545; -fx-text-fill: white;" text="Удалить" />
        </HBox>
    </VBox>
</VBox>